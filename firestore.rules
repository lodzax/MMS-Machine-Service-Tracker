rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, name, email, role (mechanic, admin), createdAt
    //
    // Collection: customers
    // Fields: name, email, phone, address, createdAt
    //
    // Collection: machinery
    // Fields: customerId, type, model, serialNumber, purchaseDate, warrantyExpiry, lastServiceDate, nextServiceDueDate, status
    //
    // Collection: serviceTickets
    // Fields: machineryId, customerId, mechanicId, status, description, openedAt, closedAt
    //
    // Collection: serviceTickets/{ticketId}/logs
    // Fields: ticketId, mechanicId, workDone, partsReplaced, usedParts, timestamp
    //
    // Collection: auditLogs
    // Fields: userId, userName, action, entityType, entityId, details, timestamp
    //
    // Collection: notifications
    // Fields: customerId, customerName, customerEmail, machineryId, machineryModel, type, status, sentAt, message
    //
    // Collection: parts
    // Fields: name, sku, description, quantity, minQuantity, unitPrice, category, updatedAt
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((request.auth.token.email == "lodzax@gmail.com" && request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Administrator'));
    }

    function isManager() {
      return isAuthenticated() && 
        (isAdmin() || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Manager'));
    }

    function isTechnician() {
      return isAuthenticated() && 
        (isManager() || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Field Technician'));
    }

    function isUser(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isValidUser(data) {
      return data.keys().hasOnly(['uid', 'name', 'email', 'role', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.email.matches('^.+@.+$') &&
             data.role in ['Field Technician', 'Manager', 'Administrator'];
    }

    function isValidCustomer(data) {
      return data.keys().hasAll(['name', 'phone', 'createdAt']) &&
             data.keys().hasOnly(['name', 'email', 'phone', 'address', 'invoiceDate', 'invoiceNumber', 'invoiceAmount', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.phone is string && data.phone.size() > 0 && data.phone.size() < 20 &&
             (!('email' in data) || (data.email is string && data.email.matches('^.+@.+$'))) &&
             (!('address' in data) || (data.address is string && data.address.size() < 200)) &&
             (!('invoiceDate' in data) || data.invoiceDate is string) &&
             (!('invoiceNumber' in data) || data.invoiceNumber is string) &&
             (!('invoiceAmount' in data) || data.invoiceAmount is number) &&
             data.createdAt is string;
    }

    function isValidMachinery(data) {
      return data.keys().hasAll(['customerId', 'type', 'model', 'serialNumber', 'warrantyExpiry']) &&
             data.keys().hasOnly(['customerId', 'type', 'model', 'serialNumber', 'purchaseDate', 'warrantyExpiry', 'lastServiceDate', 'nextServiceDueDate', 'status']) &&
             data.customerId is string &&
             data.type in ['Tractor', 'Generator', 'Water pump', 'Electric Motors', 'Transformers', 'Bow Mills', 'Jaw Crusher', 'Electric Compressors', 'Diesel Compressors', 'Engines'] &&
             data.model is string && data.model.size() > 0 && data.model.size() < 100 &&
             data.serialNumber is string && data.serialNumber.size() > 0 && data.serialNumber.size() < 100 &&
             data.warrantyExpiry is string &&
             (!('status' in data) || data.status in ['Operational', 'Due for Service', 'Under Repair']);
    }

    function isValidTicket(data) {
      return data.keys().hasAll(['machineryId', 'customerId', 'status', 'openedAt']) &&
             data.keys().hasOnly(['machineryId', 'customerId', 'mechanicId', 'status', 'description', 'openedAt', 'closedAt']) &&
             data.machineryId is string &&
             data.customerId is string &&
             data.status in ['Open', 'In Progress', 'Completed'] &&
             data.openedAt is string;
    }

    function isValidLog(data) {
      return data.keys().hasAll(['ticketId', 'mechanicId', 'workDone', 'timestamp']) &&
             data.keys().hasOnly(['ticketId', 'mechanicId', 'workDone', 'partsReplaced', 'usedParts', 'timestamp']) &&
             data.ticketId is string &&
             data.mechanicId is string &&
             data.workDone is string && data.workDone.size() > 0 && data.workDone.size() < 2000 &&
             (!('partsReplaced' in data) || (data.partsReplaced is string && data.partsReplaced.size() < 1000)) &&
             (!('usedParts' in data) || (data.usedParts is list));
    }

    function isValidPart(data) {
      return data.keys().hasAll(['name', 'sku', 'quantity', 'unitPrice']) &&
             data.keys().hasOnly(['name', 'sku', 'description', 'quantity', 'minQuantity', 'unitPrice', 'category', 'updatedAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.sku is string && data.sku.size() > 0 && data.sku.size() < 50 &&
             data.quantity is int &&
             data.unitPrice is number &&
             (!('description' in data) || (data.description is string && data.description.size() < 1000)) &&
             (!('minQuantity' in data) || data.minQuantity is int) &&
             (!('category' in data) || (data.category is string && data.category.size() < 100)) &&
             (!('updatedAt' in data) || data.updatedAt is string);
    }

    function isValidAuditLog(data) {
      return data.keys().hasAll(['userId', 'userName', 'action', 'entityType', 'entityId', 'timestamp']) &&
             data.keys().hasOnly(['userId', 'userName', 'action', 'entityType', 'entityId', 'details', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.userName is string &&
             data.action is string &&
             data.entityType is string &&
             data.entityId is string &&
             data.timestamp is string;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['type', 'status', 'sentAt', 'message']) &&
             data.keys().hasOnly(['customerId', 'customerName', 'customerEmail', 'machineryId', 'machineryModel', 'partId', 'partName', 'type', 'status', 'sentAt', 'message']) &&
             (!('customerId' in data) || data.customerId is string) &&
             (!('customerName' in data) || data.customerName is string) &&
             (!('customerEmail' in data) || data.customerEmail is string) &&
             (!('machineryId' in data) || data.machineryId is string) &&
             (!('machineryModel' in data) || data.machineryModel is string) &&
             (!('partId' in data) || data.partId is string) &&
             (!('partName' in data) || data.partName is string) &&
             data.type in ['SERVICE_REMINDER', 'LOW_STOCK'] &&
             data.status in ['SENT', 'FAILED', 'MOCKED', 'SYSTEM'] &&
             data.sentAt is string &&
             data.message is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if (isUser(uid) || isAdmin()) && isValidUser(request.resource.data);
      allow update: if (isAdmin() || (isUser(uid) && request.resource.data.role == resource.data.role)) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /customers/{customerId} {
      allow read: if isTechnician();
      allow create: if isManager() && isValidCustomer(request.resource.data);
      allow update: if isManager() && isValidCustomer(request.resource.data);
      allow delete: if isAdmin();
    }

    match /machinery/{machineryId} {
      allow read: if isTechnician();
      allow create: if isManager() && isValidMachinery(request.resource.data);
      allow update: if isManager() && isValidMachinery(request.resource.data);
      allow delete: if isAdmin();
    }

    match /serviceTickets/{ticketId} {
      allow read: if isTechnician();
      allow create: if isTechnician() && isValidTicket(request.resource.data);
      allow update: if isTechnician() && isValidTicket(request.resource.data);
      allow delete: if isAdmin();

      match /logs/{logId} {
        allow read: if isTechnician();
        allow create: if isTechnician() && isValidLog(request.resource.data);
        allow update: if isTechnician() && isValidLog(request.resource.data);
        allow delete: if isAdmin();
      }
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidAuditLog(request.resource.data);
      allow update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if isTechnician();
      allow create: if isTechnician() && isValidNotification(request.resource.data);
      allow update, delete: if false;
    }

    match /parts/{partId} {
      allow read: if isAuthenticated();
      allow create: if isManager() && isValidPart(request.resource.data);
      allow update: if (isManager() && isValidPart(request.resource.data)) || 
                      (isTechnician() && 
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['quantity', 'updatedAt']) &&
                       isValidPart(request.resource.data));
      allow delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
