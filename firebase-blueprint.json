{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user (Mechanic or Admin)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["mechanic", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Client who owns machinery",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "phone"]
    },
    "Machinery": {
      "title": "Machinery",
      "description": "Machine owned by a customer",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "type": { "type": "string", "enum": ["Tractor", "Generator", "Water pump"] },
        "model": { "type": "string" },
        "serialNumber": { "type": "string" },
        "purchaseDate": { "type": "string", "format": "date" },
        "warrantyExpiry": { "type": "string", "format": "date" },
        "lastServiceDate": { "type": "string", "format": "date" },
        "nextServiceDueDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Operational", "Due for Service", "Under Repair"] }
      },
      "required": ["customerId", "type", "model", "serialNumber", "warrantyExpiry"]
    },
    "ServiceTicket": {
      "title": "Service Ticket",
      "description": "A ticket for a service job",
      "type": "object",
      "properties": {
        "machineryId": { "type": "string" },
        "customerId": { "type": "string" },
        "mechanicId": { "type": "string" },
        "status": { "type": "string", "enum": ["Open", "In Progress", "Completed"] },
        "description": { "type": "string" },
        "openedAt": { "type": "string", "format": "date-time" },
        "closedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["machineryId", "customerId", "status", "openedAt"]
    },
    "ServiceLog": {
      "title": "Service Log",
      "description": "A log entry for work done on a ticket",
      "type": "object",
      "properties": {
        "ticketId": { "type": "string" },
        "mechanicId": { "type": "string" },
        "workDone": { "type": "string" },
        "partsReplaced": { "type": "string" },
        "usedParts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "partId": { "type": "string" },
              "partName": { "type": "string" },
              "quantity": { "type": "integer" }
            }
          }
        },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["ticketId", "mechanicId", "workDone", "timestamp"]
    },
    "Part": {
      "title": "Part",
      "description": "Inventory item for machinery parts",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "description": { "type": "string" },
        "quantity": { "type": "integer" },
        "minQuantity": { "type": "integer" },
        "unitPrice": { "type": "number" },
        "category": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "sku", "quantity", "unitPrice"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "A log entry for a significant change in the system",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "entityType": { "type": "string" },
        "entityId": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "action", "entityType", "entityId", "timestamp"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification sent to a customer or system alert",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "machineryId": { "type": "string" },
        "machineryModel": { "type": "string" },
        "partId": { "type": "string" },
        "partName": { "type": "string" },
        "type": { "type": "string", "enum": ["SERVICE_REMINDER", "LOW_STOCK"] },
        "status": { "type": "string", "enum": ["SENT", "FAILED", "MOCKED", "SYSTEM"] },
        "sentAt": { "type": "string", "format": "date-time" },
        "message": { "type": "string" }
      },
      "required": ["type", "status", "sentAt", "message"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/customers/{customerId}": { "schema": "Customer", "description": "Customer records" },
    "/machinery/{machineryId}": { "schema": "Machinery", "description": "Machinery records" },
    "/serviceTickets/{ticketId}": { "schema": "ServiceTicket", "description": "Service tickets" },
    "/serviceTickets/{ticketId}/logs/{logId}": { "schema": "ServiceLog", "description": "Logs for a specific ticket" },
    "/auditLogs/{logId}": { "schema": "AuditLog", "description": "System audit logs" },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "Sent notifications" },
    "/parts/{partId}": { "schema": "Part", "description": "Inventory parts" }
  }
}
